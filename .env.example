# GitHub OAuth App credentials (required)
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Callback URL for GitHub OAuth (required for production)
# Must match the Authorization callback URL in your GitHub OAuth App settings.
# Defaults to http://localhost:6270/auth/github/callback if not set.
# Examples:
#   GITHUB_REDIRECT_URL=https://yourdomain.com/auth/github/callback
#   GITHUB_REDIRECT_URL=http://localhost:6270/auth/github/callback
GITHUB_REDIRECT_URL=

# Server port (optional, defaults to 6270)
# PORT=6270

# SQLite database path (optional, defaults to gitlens.db)
# DB_PATH=gitlens.db

# GitHub webhook secret (optional, for verifying webhook payloads)
# GITHUB_WEBHOOK_SECRET=

# Forgejo OAuth2 credentials (optional — omit for GitHub-only deployments)
# Create an OAuth2 application in your Forgejo instance Settings -> Applications.
# FORGEJO_CLIENT_ID=
# FORGEJO_CLIENT_SECRET=

# Forgejo callback URL (optional, defaults to <APP_URL>/auth/forgejo/callback)
# FORGEJO_REDIRECT_URL=https://yourdomain.com/auth/forgejo/callback

# Default Forgejo instance base URL (optional, skip the instance prompt on login)
# Example: FORGEJO_DEFAULT_URL=https://codeberg.org
# FORGEJO_DEFAULT_URL=

# Release → Docker deploy (optional)
# On a GitHub release webhook, GitLens can pull a new Docker image and restart
# the matching container. Requires DEPLOY_TARGETS (or DEPLOY_TARGETS_FILE) to
# map repositories to images and containers. The host must have the Docker CLI
# installed and the GitLens process must have access to the Docker socket.

# JSON array of deploy targets:
#   repository:   GitHub "owner/repo" full name (required)
#   image:        Docker image to pull (required)
#   container:    Docker container to recreate (required)
#   tag_strategy: "release_tag" (default, strips leading "v") or "latest"
# Example:
#   DEPLOY_TARGETS=[{"repository":"martynvdijke/gitlens","image":"ghcr.io/martynvdijke/gitlens","container":"gitlens","tag_strategy":"release_tag"}]
# DEPLOY_TARGETS=
# DEPLOY_TARGETS_FILE=/path/to/targets.json

# Container label auto-discovery (alternative to DEPLOY_TARGETS):
# Any running Docker container with the label gitlens.deploy.target=owner/repo
# is automatically added as a deploy target. The image name and container name
# are inferred from the container's runtime config. Explicit DEPLOY_TARGETS
# always override discovered targets for the same repository.
# Example docker-compose.yml:
#   services:
#     gitlens:
#       labels:
#         gitlens.deploy.target: "martynvdijke/gitlens"

# Deploy backend: "api" (default, docker pull+recreate) or "compose" (docker compose pull+up)
# DEPLOY_BACKEND=api

# Allow prerelease publishes to trigger a deploy (default: false)
# DEPLOY_ALLOW_PRERELEASE=false

# Gotify push notification (optional)
# When configured, deploy success/failure is sent as a Gotify message.
# GOTIFY_URL=http://gotify:8080
# GOTIFY_TOKEN=
