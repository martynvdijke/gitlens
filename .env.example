# GitHub OAuth App credentials (required)
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Callback URL for GitHub OAuth (required for production)
# Must match the Authorization callback URL in your GitHub OAuth App settings.
# Defaults to http://localhost:6270/auth/github/callback if not set.
# Examples:
#   GITHUB_REDIRECT_URL=https://yourdomain.com/auth/github/callback
#   GITHUB_REDIRECT_URL=http://localhost:6270/auth/github/callback
GITHUB_REDIRECT_URL=

# Server port (optional, defaults to 6270)
# PORT=6270

# SQLite database path (optional, defaults to gitlens.db)
# DB_PATH=gitlens.db

# GitHub webhook secret (optional, for verifying webhook payloads)
# GITHUB_WEBHOOK_SECRET=

# Forgejo OAuth2 credentials (optional — omit for GitHub-only deployments)
# Create an OAuth2 application in your Forgejo instance Settings -> Applications.
# FORGEJO_CLIENT_ID=
# FORGEJO_CLIENT_SECRET=

# Forgejo callback URL (optional, defaults to <APP_URL>/auth/forgejo/callback)
# FORGEJO_REDIRECT_URL=https://yourdomain.com/auth/forgejo/callback

# Default Forgejo instance base URL (optional, skip the instance prompt on login)
# Example: FORGEJO_DEFAULT_URL=https://codeberg.org
# FORGEJO_DEFAULT_URL=
